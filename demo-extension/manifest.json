{
  "manifest_version": 3,
  "name": "OpenAI Agent",
  "version": "2.0",
  "description": "AI agent powered by OpenAI Agents SDK + Webfuse MCP",
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png"
  },
  "env": [
    { "key": "AGENT_URL", "value": "", "description": "Agent backend URL" }
  ]
}
