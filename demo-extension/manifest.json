{
  "manifest_version": 3,
  "name": "OpenAI Agent Demo",
  "version": "1.2",
  "description": "AI agent controlling a live browser via Webfuse MCP",
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "host_permissions": ["https://openai-agent.webfuse.it/*"],
  "env": [
    { "key": "AGENT_URL", "value": "", "description": "Agent server URL (e.g. https://openai-agent.webfuse.it)" }
  ]
}
